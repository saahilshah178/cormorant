# Copy to .env.local and fill in. None of these are NEXT_PUBLIC_-prefixed:
# all secrets stay server-side (see lib/supabase.ts, lib/models.ts).

# OpenAI — scoring + discovery LLM calls
OPENAI_API_KEY=

# Supabase — server-side (service-role / secret key) access only
SUPABASE_URL=
SUPABASE_SECRET_KEY=

# Supabase — public client (browser + server auth session only, no data access).
# Enable Google as an auth provider in the Supabase dashboard
# (Authentication -> Providers -> Google) and add the Google OAuth client
# id/secret there. Add http://localhost:3000/auth/callback (and the prod
# equivalent) under Authentication -> URL Configuration -> Redirect URLs.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
